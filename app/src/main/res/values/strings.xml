    <string name="onboard_all_set">All set — continue</string>
    <string name="onboard_setup_summary_ok">Permissions look good. Enforce is ready — you can change it anytime on the main screen.</string>
    <string name="onboard_setup_summary_missing">Still missing: %1$s. You can finish later from the setup card on the main screen.</string>

    <string name="onboard_3_title">Tap an app → pick orientation</string>
    <string name="onboard_3_body">Rules apply only while that app is open. Leaving restores your previous system rotation.</string>
    <string name="onboard_3_tip">Tip: Auto follows the tablet tilt using the same force-lock as Landscape. For a fixed direction, pick Landscape or Portrait.</string>
