    <string name="onboard_1_title">Per-app screen orientation</string>
    <string name="onboard_1_body">Force games to landscape, readers to portrait, or turn auto-rotate on for a single app. No root required.</string>

    <string name="onboard_2_title">Enable permissions</string>
    <string name="onboard_2_body">Grant these here. After each system screen, come back — status updates automatically. No root.</string>
    <string name="onboard_2_a11y_title">Accessibility</string>
    <string name="onboard_2_a11y_body">Sees only which app is in the foreground — not passwords or screen content. Find “Rotation Control” and turn it on.</string>
    <string name="onboard_2_write_title">Modify system settings</string>
    <string name="onboard_2_write_body">Lets the app lock orientation and apply Auto force-locks. Toggle allow for Rotation Control.</string>
    <string name="onboard_2_hint">Accessibility is required. Modify system settings is strongly recommended for reliable locks.</string>
